{
  "id": "K8s Container Escape - Spring4Shell Containment",
  "version": -1,
  "name": "K8s Container Escape - Spring4Shell Containment",
  "description": "Automated incident response playbook for Spring4Shell (CVE-2022-22965) container escape on EKS. Orchestrates containment via AWS Lambda to isolate compromised pods, revoke RBAC, apply NetworkPolicies, and collect forensic evidence.",
  "starttaskid": "0",
  "tasks": {
    "0": {
      "id": "0",
      "taskid": "start",
      "type": "start",
      "task": {
        "id": "start",
        "name": "",
        "iscommand": false,
        "brand": "",
        "description": ""
      },
      "nexttasks": {
        "#none#": ["1"]
      },
      "separatecontext": false,
      "view": { "position": { "x": 450, "y": 50 } }
    },
    "1": {
      "id": "1",
      "taskid": "triage",
      "type": "regular",
      "task": {
        "id": "triage",
        "name": "Triage - Detect Spring4Shell Indicators",
        "description": "Check for Spring4Shell RCE indicators: webshell creation (shell.jsp), suspicious class loader manipulation, CVE-2022-22965 signatures in WAF/IDS logs.",
        "iscommand": false,
        "brand": ""
      },
      "nexttasks": {
        "#none#": ["2"]
      },
      "scriptarguments": {},
      "separatecontext": false,
      "view": { "position": { "x": 450, "y": 200 } }
    },
    "2": {
      "id": "2",
      "taskid": "collect_evidence",
      "type": "regular",
      "task": {
        "id": "collect_evidence",
        "name": "Collect Evidence - Pod Forensics",
        "description": "Invoke Lambda to collect forensic evidence: pod config (privileged, hostPID, hostNetwork, hostPath), pod logs, events, RBAC bindings, service account tokens.",
        "iscommand": true,
        "brand": "AWS - Lambda",
        "script": "aws-lambda-invoke"
      },
      "scriptarguments": {
        "functionName": { "simple": "k8s-escape-demo-containment" },
        "payload": { "simple": "{\"action\": \"collect_evidence\", \"cluster_name\": \"eks-escape-demo\", \"namespace\": \"vuln-app\"}" },
        "region": { "simple": "eu-west-3" }
      },
      "nexttasks": {
        "#none#": ["3"]
      },
      "separatecontext": false,
      "view": { "position": { "x": 450, "y": 370 } }
    },
    "3": {
      "id": "3",
      "taskid": "severity_check",
      "type": "condition",
      "task": {
        "id": "severity_check",
        "name": "Auto-Contain?",
        "description": "Check severity. If privileged pod with cluster-admin SA detected, auto-contain. Otherwise, request analyst approval.",
        "iscommand": false,
        "brand": ""
      },
      "conditions": [
        {
          "label": "Critical - Auto-Contain",
          "condition": [
            [
              {
                "left": { "value": { "simple": "${incident.severity}" } },
                "operator": "isEqualNumber",
                "right": { "value": { "simple": "4" } }
              }
            ]
          ]
        }
      ],
      "nexttasks": {
        "Critical - Auto-Contain": ["4"],
        "#default#": ["3a"]
      },
      "separatecontext": false,
      "view": { "position": { "x": 450, "y": 540 } }
    },
    "3a": {
      "id": "3a",
      "taskid": "manual_approval",
      "type": "condition",
      "task": {
        "id": "manual_approval",
        "name": "Analyst Approval Required",
        "description": "Analyst must approve containment actions before proceeding. Review evidence and confirm.",
        "iscommand": false,
        "brand": ""
      },
      "nexttasks": {
        "Approve": ["4"],
        "Reject": ["9"]
      },
      "separatecontext": false,
      "view": { "position": { "x": 700, "y": 700 } }
    },
    "4": {
      "id": "4",
      "taskid": "network_isolate",
      "type": "regular",
      "task": {
        "id": "network_isolate",
        "name": "Step 1 - Network Isolation",
        "description": "Apply deny-all NetworkPolicy on the vuln-app namespace to block all ingress and egress traffic. This immediately stops the attacker's C2 communication and prevents lateral movement.",
        "iscommand": true,
        "brand": "AWS - Lambda",
        "script": "aws-lambda-invoke"
      },
      "scriptarguments": {
        "functionName": { "simple": "k8s-escape-demo-containment" },
        "payload": { "simple": "{\"action\": \"network_isolate\", \"cluster_name\": \"eks-escape-demo\", \"namespace\": \"vuln-app\"}" },
        "region": { "simple": "eu-west-3" }
      },
      "nexttasks": {
        "#none#": ["5"]
      },
      "separatecontext": false,
      "view": { "position": { "x": 450, "y": 870 } }
    },
