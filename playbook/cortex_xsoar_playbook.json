      "id": "7",
      "taskid": "cordon_node",
      "type": "regular",
      "task": {
        "id": "cordon_node",
        "name": "Step 4 - Cordon Compromised Node",
        "description": "Mark the node that ran the compromised pod as unschedulable. This prevents new workloads from being placed on a potentially compromised host.",
        "iscommand": true,
        "brand": "AWS - Lambda",
        "script": "aws-lambda-invoke"
      },
      "scriptarguments": {
        "functionName": { "simple": "k8s-escape-demo-containment" },
        "payload": { "simple": "{\"action\": \"cordon_node\", \"cluster_name\": \"eks-escape-demo\", \"namespace\": \"vuln-app\"}" },
        "region": { "simple": "eu-west-3" }
      },
      "nexttasks": {
