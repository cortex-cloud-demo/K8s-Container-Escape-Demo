      "id": "6",
      "taskid": "scale_down",
      "type": "regular",
      "task": {
        "id": "scale_down",
        "name": "Step 3 - Scale Down Deployment",
        "description": "Scale the vuln-app deployment to 0 replicas. This terminates all running pods while preserving the deployment configuration for forensic analysis.",
        "iscommand": true,
        "brand": "AWS - Lambda",
        "script": "aws-lambda-invoke"
      },
      "scriptarguments": {
        "functionName": { "simple": "k8s-escape-demo-containment" },
        "payload": { "simple": "{\"action\": \"scale_down\", \"cluster_name\": \"eks-escape-demo\", \"namespace\": \"vuln-app\"}" },
        "region": { "simple": "eu-west-3" }
