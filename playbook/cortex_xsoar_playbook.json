      "id": "8",
      "taskid": "delete_pod",
      "type": "regular",
      "task": {
        "id": "delete_pod",
        "name": "Step 5 - Kill Compromised Pods",
        "description": "Force delete all pods in the vuln-app namespace. Combined with scale-down, this ensures no compromised containers remain running.",
        "iscommand": true,
        "brand": "AWS - Lambda",
        "script": "aws-lambda-invoke"
      },
      "scriptarguments": {
        "functionName": { "simple": "k8s-escape-demo-containment" },
        "payload": { "simple": "{\"action\": \"delete_pod\", \"cluster_name\": \"eks-escape-demo\", \"namespace\": \"vuln-app\"}" },
        "region": { "simple": "eu-west-3" }
      },
      "nexttasks": {
        "#none#": ["9"]
