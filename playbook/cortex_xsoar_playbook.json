      "id": "5",
      "taskid": "revoke_rbac",
      "type": "regular",
      "task": {
        "id": "revoke_rbac",
        "name": "Step 2 - Revoke RBAC Privileges",
        "description": "Delete the cluster-admin ClusterRoleBinding for the vuln-app ServiceAccount. This revokes full cluster access and prevents further K8s API abuse (secret exfiltration, lateral movement).",
        "iscommand": true,
        "brand": "AWS - Lambda",
        "script": "aws-lambda-invoke"
      },
      "scriptarguments": {
        "functionName": { "simple": "k8s-escape-demo-containment" },
        "payload": { "simple": "{\"action\": \"revoke_rbac\", \"cluster_name\": \"eks-escape-demo\", \"namespace\": \"vuln-app\"}" },
        "region": { "simple": "eu-west-3" }
      },
      "nexttasks": {
        "#none#": ["6"]
      },
      "separatecontext": false,
      "view": { "position": { "x": 450, "y": 1040 } }
    },
